{
  "repository": "pypa/warehouse",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "build": "rspack build",
    "watch": "rspack build --watch",
    "lint": "oxlint && oxfmt --check warehouse/static/js warehouse/admin/static/js tests/frontend rspack.config.js rspack.plugin.localize.js rspack.plugin.manifest.js bin/post-build.mjs",
    "lint:fix": "oxlint --fix && oxfmt warehouse/static/js warehouse/admin/static/js tests/frontend rspack.config.js rspack.plugin.localize.js rspack.plugin.manifest.js bin/post-build.mjs",
    "stylelint": "stylelint '**/*.scss' --cache",
    "stylelint:fix": "stylelint '**/*.scss' --cache --fix",
    "test": "NODE_OPTIONS='$NODE_OPTIONS --experimental-vm-modules' jest --coverage"
  },
  "jest": {
    "setupFilesAfterEnv": [
      "./tests/frontend/setup.js"
    ],
    "testEnvironment": "jsdom",
    "testRegex": ".*_test.js"
  },
  "dependencies": {
    "@fontsource/ewert": "^5.2.8",
    "@fontsource/source-code-pro": "^5.2.7",
    "@fontsource/source-sans-3": "^5.2.9",
    "@fortawesome/fontawesome-free": "^7.1.0",
    "@hotwired/stimulus": "^3.2.1",
    "@hotwired/stimulus-webpack-helpers": "^1.0.1",
    "@zxcvbn-ts/core": "^3.0.4",
    "@zxcvbn-ts/language-common": "^3.0.4",
    "@zxcvbn-ts/language-en": "^3.0.2",
    "admin-lte": "^3.2.0",
    "date-fns": "^4.1.0",
    "debounce": "^1.2.1",
    "jquery": "^3.7.0",
    "normalize.css": "^8.0.1",
    "stimulus-autocomplete": "^3.1.0"
  },
  "overrides": {
    "datatables.net": "^1.13.11",
    "datatables.net-rowgroup-bs4": "<1.5.1",
    "datatables.net-searchbuilder": "<1.8.1",
    "datatables.net-searchpanes": "<2.3.2",
    "sweetalert2": "11.4.8"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@rspack/cli": "^2.0.0",
    "@rspack/core": "^2.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "babel-jest": "^30.2.0",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "gettext-parser": "^9.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-fetch-mock": "^3.0.3",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "postcss-loader": "^8.1.1",
    "rtlcss": "^4.0.0",
    "sass-embedded": "^1.57.1",
    "sass-loader": "^16.0.4",
    "sharp": "^0.34.0",
    "stylelint": "^16.6.1",
    "stylelint-config-standard-scss": "^14.0.0",
    "stylelint-selector-bem-pattern": "^4.0.0",
    "svgo": "^3.0.2",
    "webpack-remove-empty-scripts": "^1.0.3"
  }
}
