#!/bin/bash

EXIT_CODE=0

# Search all .py files
for fn in $(fd --type f \
            --extension py \
            --extension html \
            --extension scss \
            --extension js \
            --exclude warehouse/static/html \
            --exclude warehouse/static/js/vendor \
            --exclude docs); do
    # Check for license in first 5 lines (allows for shebang, encoding and handles comment character in various languages)
    if [[ ! "$(head -5 $fn | grep "^ *\(#\|\*\|\/\/\|\/\*\|{#\).*License")" ]]; then
        echo $fn is missing a license
        EXIT_CODE=1
    fi
done

exit $EXIT_CODE
