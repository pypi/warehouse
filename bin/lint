#!/bin/bash
set -ex


# When on GitHub Actions, configure ruff to use the github output style
if [ -n "$GITHUB_ACTIONS" ]; then
  export RUFF_OUTPUT_FORMAT=github
fi

# Actually run our tests.
ruff check
ruff format --check --diff
python -m flake8 .
sphinx-lint --enable=all --disable=line-too-long README.rst CONTRIBUTING.rst docs/dev/ --ignore=docs/dev/_build/
python -m djlint --check --lint ./warehouse/templates ./docs/blog
python -m mypy -p warehouse
./bin/flushes

# lint our pyproject.toml file (as well as any other toml files)
tombi lint --error-on-warnings
tombi format --check --diff
